<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AssemblyName>AppsettingsDiff</AssemblyName>
    <RootNamespace>AppsettingsDiff</RootNamespace>
    <PackageId>AppsettingsDiff</PackageId>
    <Version>0.1.0</Version>
    <Authors>Vladyslav Zaiets</Authors>
    <Description>Diffs appsettings across environments and finds keys missing between them.</Description>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.0" />
  </ItemGroup>
</Project>
